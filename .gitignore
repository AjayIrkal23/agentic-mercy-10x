# ============================================================
# ~/.claude .gitignore — local safety repo + public open-source
# Rule: if it's a secret, a session artifact, personal data,
# or re-installable from elsewhere, it does NOT get committed.
# ============================================================

# --- secrets & auth (NEVER commit) ---
.credentials.json
# per-machine claude state/config (machineID, userID, oauthAccount, MCP creds).
# canonical home is ~/.claude.json; a stray copy can appear here if CLAUDE_CONFIG_DIR
# points at the repo root — never commit either.
.claude.json
mcp-needs-auth-cache.json
*.pem
*.key
**/.env
**/.env.*
!**/.env.example

# --- personal / session data (private, never public) ---
history.jsonl
projects/
session-env/
sessions/
file-history/
paste-cache/
ide/
daemon/
daemon.log
jobs/
cache/
downloads/
todos/
statsig/
shell-snapshots/
.audit/
.backups/
backups/
agent-memory/
double-shot-latte/
improvements/
plans/
gsd-migration-journal/

# --- runtime state (regenerated every session) ---
state/
hooks/.state/
hooks/.telemetry/
hooks/.agents/
**/__pycache__/
# 100x overhaul (P0): runtime tmp / lock / telemetry litter
*.tmp.*
daemon.lock
daemon.status.json
telemetry/*.jsonl
# 100x overhaul (P0-T5): gitignored-class litter relocated into attic
# (recoverable on disk, deliberately not committed to avoid re-bloating the repo)
attic/2026-07-11/skills/gstack/
attic/2026-07-11/hooks/.agents/
.ponytail-active
.blast-bypass
.gateguard-last-impact.md
.gsd-profile
.last-cleanup
.last-update-result.json

# --- config backups & editor droppings ---
*.bak*
*.bak
*.bak.*
*.bak-*
*.bak2.*
*.bak3.*
settings.json.bak*
*.backup-*
hooks-rules-claudemd.backup-*.tgz
*.presp.*
installed_plugins.json.presp.*

# --- re-installable externals (install script fetches these) ---
plugins/cache/
plugins/marketplaces/
plugins/data/
plugins/plugin-catalog-cache.json
skills/gstack/
skills/node_modules/
skills/package-lock.json
ast-grep-mcp/
get-shit-done/

# --- large generated assets inside kept skills ---
skills/*/dist/
skills/*/node_modules/
.gstack/

# --- session task state (runtime noise) ---
tasks/
image-cache/

# --- machine-specific state (per-user; regenerated on the target machine) ---
# Local settings override (Claude Code convention: never shared)
settings.local.json
# settings.json is a RENDERED artifact (P6-T3): installer/render.py generates it
# from settings.template.json (tracked source of truth) ⊕ settings.user.json
# (per-machine overlay). The rendered output + the overlay are per-machine and
# never shared; a fresh clone runs `python install.py` to render them.
settings.json
settings.user.json
# Plugin manifests point at this machine's absolute cache paths + list private
# project roots; the target reinstalls via `claude plugin install` (see install.sh)
plugins/installed_plugins.json
plugins/known_marketplaces.json
# jcodemunch/jdocmunch index-guard configs (machine-private project roots) —
# retired to attic P3-T3; kept gitignored at their new home so /DATA paths and
# private project names never enter git (public repo)
attic/2026-07-11/hooks/jcodemunch-index-guard.config.json
attic/2026-07-11/hooks/jdocmunch-index-guard.config.json
# dox / tdd-guard auto-init sidecars created for THIS repo (fingerprints + state)
.claude/
vendor/gstack-deps/node_modules/

# lean-ctx runtime shims — the lean-ctx MCP binary regenerates these hook
# wrappers every session (redirect/rewrite, .sh + -native). Never committed;
# absent from a fresh checkout. The G4 portability gate skips gitignored files.
hooks/lean-ctx-redirect*
hooks/lean-ctx-rewrite*

# Santa Method review reports — per-diff artifacts written by the santa-reviewer
# agent / /santa-review; regenerated on demand, not workflow source.
SANTA-REVIEW.md

# --- generated code-intelligence + runtime parity artifacts (never committed) ---
# graphify knowledge graph for THIS repo (~38MB, regenerated by `graphify update`)
graphify-out/
# trigger-parity harness output (run_fixtures / run_session write per-run jsonl;
# the real fixtures are _FIXTURES in hooks/tools/trigger-parity-diff.py)
telemetry/**/*.jsonl

# personal uploads + ephemeral agent inboxes — never publish (repo is public)
uploads/
teams/*/inboxes/
teams/*/config.json
hooks/*.bak-*
