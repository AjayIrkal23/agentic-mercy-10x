{
  "skillListingBudgetFraction": 0.1,
  "env": {
    "CLAUDE_CODE_SUBAGENT_EFFORT": "max",
    "TDD_GUARD_MODEL_VERSION": "claude-sonnet-4-0",
    "VALIDATION_CLIENT": "sdk"
  },
  "permissions": {
    "deny": [
      "Read",
      "Grep",
      "Glob"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py post-tool-use",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "(AskUserQuestion|mcp__.*__AskUserQuestion)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.claude/skills/gstack/hosts/claude/hooks/question-log-hook",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook observe"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook read-dedup"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py pre-compact",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py pre-tool-use",
            "timeout": 65
          }
        ]
      },
      {
        "matcher": "(AskUserQuestion|mcp__.*__AskUserQuestion)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.claude/skills/gstack/hosts/claude/hooks/question-preference-hook",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/mercy/.nvm/versions/node/v24.18.0/bin/node\" \"/home/mercy/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook rewrite"
          }
        ]
      },
      {
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory|Glob|glob",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook redirect"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py session-end",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py session-start",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py stop",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/dispatch.py subagent-stop",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/hooks/prompt_router/router.py",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mercy/.local/bin/lean-ctx hook observe"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"${HOME}/.local/bin/node\" \"${HOME}/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-mermaid@claude-mermaid": true,
    "claude-session-driver@superpowers-marketplace": true,
    "clickhouse@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true,
    "firecrawl@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "superpowers-lab@superpowers-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-mermaid": {
      "source": {
        "source": "github",
        "repo": "veelenga/claude-mermaid"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "xhigh",
  "autoCompactWindow": 900000,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "contextWindow": 1000000,
  "mcpServers": {
    "ast-grep": {
      "args": [
        "run",
        "--directory",
        "${HOME}/.claude/ast-grep-mcp",
        "python",
        "main.py"
      ],
      "command": "uv"
    },
    "browser-tools-mcp": {
      "args": [
        "-y",
        "@agentdeskai/browser-tools-mcp@latest"
      ],
      "command": "npx"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "command": "npx"
    },
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    },
    "figma": {
      "args": [
        "-y",
        "@anthropic-ai/figma-mcp@latest"
      ],
      "command": "npx"
    },
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "graphify": {
      "args": [],
      "command": "${HOME}/.claude/hooks/graphify_launcher.py"
    },
    "jcodemunch": {
      "args": [],
      "command": "jcodemunch-mcp"
    },
    "jdocmunch": {
      "args": [],
      "command": "jdocmunch-mcp"
    },
    "lean-ctx": {
      "args": [
        "mcp"
      ],
      "command": "lean-ctx"
    },
    "markdownify": {
      "args": [
        "-y",
        "mcp-markdownify-server"
      ],
      "command": "npx"
    },
    "memory": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "command": "npx"
    },
    "playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headed"
      ],
      "command": "npx"
    },
    "semgrep": {
      "args": [
        "mcp"
      ],
      "command": "${HOME}/.local/bin/semgrep"
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    }
  }
}
