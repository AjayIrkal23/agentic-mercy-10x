{
  "agentPushNotifEnabled": true,
  "autoCompactWindow": 900000,
  "contextWindow": 1000000,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-mermaid@claude-mermaid": true,
    "claude-session-driver@superpowers-marketplace": true,
    "clickhouse@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true,
    "firecrawl@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "supabase@claude-plugins-official": true,
    "superpowers-lab@superpowers-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_EFFORT": "max",
    "TDD_GUARD_MODEL_VERSION": "claude-sonnet-4-0",
    "VALIDATION_CLIENT": "sdk"
  },
  "extraKnownMarketplaces": {
    "claude-mermaid": {
      "source": {
        "repo": "veelenga/claude-mermaid",
        "source": "github"
      }
    },
    "karpathy-skills": {
      "source": {
        "repo": "forrestchang/andrej-karpathy-skills",
        "source": "github"
      }
    },
    "ponytail": {
      "source": {
        "repo": "DietrichGebert/ponytail",
        "source": "github"
      }
    },
    "superpowers-marketplace": {
      "autoUpdate": true,
      "source": {
        "repo": "obra/superpowers-marketplace",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/skill-invocation-tracker.py",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/ponytail-caveman-guard.py post-skill",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Skill"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/fullstack-skills-reminder.py post-tool-use",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/codex-capture.py",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/post-write-aggregator.py",
            "timeout": 12,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/ui-ux-stack-orchestrator.py post-tool-use",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "bash \"${HOME}/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/desloppify-cleanup.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/santa-method-writer.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Task|Agent"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/security-semgrep-tracker.py post-tool-use",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "lean-ctx hook observe",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "\"/usr/bin/node\" \"${HOME}/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit|Task|Agent"
      },
      {
        "hooks": [
          {
            "command": "\"/usr/bin/node\" \"${HOME}/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Read"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/jcodemunch-enforce.py mcp-used",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "mcp__jcodemunch__.*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/session-lifecycle.py pre-compact",
            "timeout": 8,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/ponytail-caveman-guard.py pre-tool-use",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/tdd-guard-launcher.sh",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit|TodoWrite"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/graphify-enforce.py pre-tool-use",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Task|Agent|Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/first-write-skill-gate.py",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/gateguard-write-gate.py",
            "timeout": 8,
            "type": "command"
          },
          {
            "command": "\"/usr/bin/node\" \"${HOME}/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "\"/usr/bin/node\" \"${HOME}/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/dox-write-gate.py",
            "timeout": 6,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/dangerous-bash-gate.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/dox-write-gate.py",
            "timeout": 6,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/bash-write-gate.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "lean-ctx hook rewrite",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "lean-ctx hook redirect",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash \"${HOME}/.claude/hooks/gsd-validate-commit.sh\"",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/blocking-doc-enforcer.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/jcodemunch-enforce.py pre-tool-use",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Read|Grep|Glob"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/opus-guard.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Agent"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/workflow-model-guard.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Workflow"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/jcodemunch-enforce.py pre-tool-use",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "mcp__lean-ctx__ctx_read|mcp__lean-ctx__ctx_search|mcp__lean-ctx__ctx_multi_read"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/watch-daemon-session-end.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/tdd-guard-launcher.sh",
            "timeout": 20,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/ponytail-caveman-guard.py session-start",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/session-start-aggregator.py",
            "timeout": 45,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/memory-bootstrap-guard.py",
            "timeout": 12,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/memory-load-on-start.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/session-lifecycle.py session-start",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "lean-ctx hook observe",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash \"${HOME}/.claude/hooks/gsd-session-state.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/hard-completion-gate.py",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/fullstack-skills-reminder.py stop",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/session-memory-writer.py",
            "timeout": 12,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/session-learning-extractor.py",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/session-lifecycle.py stop",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "lean-ctx hook observe",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/weekly-retro-trigger.py stop",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/invoke-suite-gate.py",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/santa-method-writer.py subagent-stop",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/session-lifecycle.py subagent-stop",
            "timeout": 8,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/tdd-guard-launcher.sh",
            "timeout": 20,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/invoke-suite-manifest.py",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "python3 ${HOME}/.claude/hooks/model-router.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/fullstack-skills-reminder.py before-submit",
            "timeout": 8,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/autonomous-skill-router.py",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/ui-ux-stack-orchestrator.py before-submit",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/token-stack-prompt-reminder.py",
            "timeout": 20,
            "type": "command"
          },
          {
            "command": "lean-ctx hook observe",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash ${HOME}/.claude/hooks/discovery-skills-reminder.sh prompt",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "python3 ${HOME}/.claude/hooks/sequential-thinking-mandate.py",
            "timeout": 8,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  },
  "mcpServers": {
    "ast-grep": {
      "args": [
        "run",
        "--directory",
        "${HOME}/.claude/ast-grep-mcp",
        "python",
        "main.py"
      ],
      "command": "uv"
    },
    "browser-tools-mcp": {
      "args": [
        "-y",
        "@agentdeskai/browser-tools-mcp@latest"
      ],
      "command": "npx"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "command": "npx"
    },
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    },
    "figma": {
      "args": [
        "-y",
        "@anthropic-ai/figma-mcp@latest"
      ],
      "command": "npx"
    },
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "graphify": {
      "args": [],
      "command": "${HOME}/.claude/hooks/graphify-mcp-launcher.sh"
    },
    "jcodemunch": {
      "args": [],
      "command": "jcodemunch-mcp"
    },
    "markdownify": {
      "args": [
        "-y",
        "mcp-markdownify-server"
      ],
      "command": "npx"
    },
    "memory": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "command": "npx"
    },
    "playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headed"
      ],
      "command": "npx"
    },
    "semgrep": {
      "args": [
        "mcp"
      ],
      "command": "${HOME}/.local/bin/semgrep"
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    }
  },
  "model": "opus[1m]",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skillListingBudgetFraction": 0.1,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "\"/usr/bin/node\" \"${HOME}/.claude/hooks/gsd-statusline.js\"",
    "type": "command"
  },
  "theme": "dark"
}