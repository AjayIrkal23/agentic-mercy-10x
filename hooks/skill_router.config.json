    ]
   },
   "skills": [
    "golang-patterns",
    "backend-standards-always-follow",
    "service-layer-standards"
   ]
  },
  {
   "id": "be_review_perf",
   "match": {
    "path_contains_any": [
     "internal/",
     "server/",
     "cmd/"
    ]
   },
   "skills": [
    "tech-debt-audit",
    "backend-performance-standards"
   ]
  },
  {
   "id": "be_debug",
   "match": {
    "filename_contains_any": [
     "debug",
