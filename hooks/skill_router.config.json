    ]
   },
   "skills": [
    "debug-investigation",
    "doubt-driven-development",
    "backend-error-handling"
   ]
  },
  {
   "id": "be_review",
   "match": {
    "path_contains_any": [
     "internal/",
     "server/",
     "controller",
