{
 "_comment": "Smart Skill Router configuration. Path-ranked skills per write; manifest_mode surfaces full FE/BE lists over the session.",
 "skills_root": "~/.claude/skills",
 "manifest_mode": true,
 "max_primary_skills": 3,
 "max_primary_skills_by_rule": {
  "fe_ui_design": 6
 },
 "frontend_rules": [
  {
   "id": "fe_api",
   "match": {
    "path_contains_any": [
     "/api/",
     "/api-client",
     "api.ts",
     "api.js"
    ]
   },
   "skills": [
    "frontend-response-handling",
    "frontend-server-data-patterns",
    "owasp-security"
   ]
  },
  {
   "id": "fe_hooks",
   "match": {
    "path_contains_any": [
     "/src/hooks/",
     "/hooks/use",
     "use-",
     "useHook",
     ".hook."
    ],
    "exclude_paths": [
     ".claude/hooks",
     "/.claude/hooks"
    ]
   },
   "skills": [
    "react-hooks-patterns",
    "frontend-server-data-patterns",
    "frontend-standards-always-follow"
   ]
  },
  {
   "id": "fe_store_redux",
   "match": {
    "path_contains_any": [
     "/store/",
     "slice.",
     "reducer.",
     "redux",
     "selector."
    ]
   },
   "skills": [
    "frontend-standards-always-follow",
    "frontend-structure-standards",
    "react-hooks-patterns"
   ]
  },
  {
   "id": "fe_routes",
   "match": {
    "path_contains_any": [
     "/routes/",
     "/router/",
     "route.tsx",
     "route.ts",
     "routes.ts"
    ],
    "exclude_paths": [
     "UDP_PLATFORM/server",
     "server/internal"
    ]
   },
   "skills": [
    "frontend-standards-always-follow",
    "frontend-structure-standards",
    "scaffold-standards"
   ]
  },
  {
   "id": "fe_types",
   "match": {
    "path_contains_any": [
     "src/types/",
     "src/schemas/"
    ]
   },
   "skills": [
    "api-contract-standards",
    "frontend-structure-standards",
    "frontend-standards-always-follow"
   ]
  },
  {
   "id": "fe_test",
   "match": {
    "path_contains_any": [
     ".test.",
     ".spec.",
     "__tests__",
     "_test.ts",
     "_test.tsx"
    ]
   },
   "skills": [
    "webapp-testing",
    "test-driven-development",
    "frontend-standards-always-follow"
   ]
  },
  {
   "id": "fe_ui_design",
   "match": {
    "path_contains_any": [
     "/components/",
     "/layout/",
     "/pages/",
     "/views/"
    ]
   },
   "skills": [
    "impeccable",
    "huashu-design",
    "ui-ux-pro-max",
    "taste-skill",
    "frontend-ui-engineering",
    "design-extract"
   ]
  },
  {
   "id": "fe_review",
   "match": {
    "path_contains_any": [
     "/components/",
     "/pages/",
     "/views/",
     ".tsx",
     ".jsx"
    ]
   },
   "skills": [
    "frontend-code-review",
    "frontend-standards-always-follow",
    "react-hooks-patterns"
   ]
  },
  {
   "id": "fe_vite_config",
   "match": {
    "filename_contains_any": [
     "vite",
     "tsconfig",
     "eslint",
     "postcss",
     "tailwind.config"
    ]
   },
   "skills": [
    "vite-react-best-practices",
    "frontend-standards-always-follow",
    "frontend-structure-standards"
   ]
  },
  {
   "id": "fe_auth",
   "match": {
    "path_contains_any": [
     "/auth/",
     "/login/",
     "/guard/",
     "protected",
     "session"
    ]
   },
   "skills": [
    "owasp-security",
    "frontend-standards-always-follow",
    "frontend-response-handling"
   ]
  },
  {
   "id": "fe_component_tsx",
   "match": {
    "extensions": [
     ".tsx",
     ".jsx"
    ]
   },
   "skills": [
    "frontend-standards-always-follow",
    "react-hooks-patterns",
    "tailwind-design-system",
    "shadcn"
   ]
  },
  {
   "id": "fe_default",
   "match": {
    "catch_all": true
   },
   "skills": [
    "frontend-standards-always-follow",
    "frontend-structure-standards",
    "react-hooks-patterns"
   ]
  }
 ],
