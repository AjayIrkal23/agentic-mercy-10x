{
 "enabled": true,
 "exemptRepos": [],
 "documentAllDirs": true,
 "autoCreateChildren": true,
 "syncRootIndex": true,
 "sweepMaxDepth": 12,
 "maxSweepDirs": 500,
 "skipPaths": [
  "~/.claude/agents",
  "~/.claude/commands",
  "~/.claude/skills",
  "~/.claude/plugins",
  "~/.claude/file-history",
  "~/.claude/jobs",
  "~/.claude/session-env",
  "~/.claude/paste-cache",
  "~/.claude/projects",
  "~/.claude/sessions",
  "~/.claude/cache",
  "~/.claude/daemon",
  "~/.claude/downloads",
  "~/.claude/backups",
  "~/.claude/tasks",
  "~/.claude/ide",
  "~/.claude/attic",
  "~/.claude/improvements"
 ],
 "significantDirThreshold": 3,
 "rootDoxMarker": "<!-- dox:root v1 -->",
 "codeExtensions": [
  ".ts",
  ".tsx",
  ".js",
  ".jsx",
  ".mjs",
  ".cjs",
  ".py",
  ".go",
  ".rs",
  ".java",
  ".kt",
  ".rb",
  ".php",
  ".c",
  ".cpp",
  ".h",
  ".hpp",
  ".swift",
  ".scala"
 ]
}