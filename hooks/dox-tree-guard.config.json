{
  "enabled": true,
  "exemptRepos": [],

  "documentAllDirs": true,
  "autoCreateChildren": true,
  "syncRootIndex": true,
  "sweepMaxDepth": 12,
  "maxSweepDirs": 500,

  "skipPaths": [
    "~/.claude/agents",
    "~/.claude/commands",
    "~/.claude/skills",
    "~/.claude/plugins"
  ],

  "significantDirThreshold": 3,
  "rootDoxMarker": "<!-- dox:root v1 -->",
  "codeExtensions": [
    ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs",
    ".py", ".go", ".rs", ".java", ".kt",
    ".rb", ".php", ".c", ".cpp", ".h", ".hpp", ".swift", ".scala"
  ]
}
